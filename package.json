{
  "name": "@danfarrdotcom/coolify-mcp",
  "version": "0.1.0",
  "description": "MCP server for Coolify — multi-instance, token-optimized, 75+ tools, smart diagnostics",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "coolify-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "generate-types": "openapi-typescript https://raw.githubusercontent.com/coollabsio/coolify/v4.x/openapi.yaml -o src/generated/coolify-api.ts"
  },
  "keywords": [
    "mcp",
    "coolify",
    "model-context-protocol",
    "self-hosted",
    "paas",
    "devops",
    "ai",
    "claude",
    "infrastructure"
  ],
  "author": "drfarr",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drfarr/coolify-mcp.git"
  },
  "homepage": "https://github.com/drfarr/coolify-mcp#readme",
  "bugs": {
    "url": "https://github.com/drfarr/coolify-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.12.1",
    "zod": "3.24.4"
  },
  "devDependencies": {
    "@types/node": "22.15.3",
    "openapi-typescript": "7.6.1",
    "rollup": "npm:@rollup/wasm-node@4.60.3",
    "tsx": "4.19.4",
    "typescript": "5.8.3",
    "vitest": "3.1.3"
  }
}
